# Production env for the single-VM deploy. Copy to .env on the server and fill in
# real values, then:
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d --pull always
#
# .env is git-ignored — never commit real secrets.

# ---- Stateful dependency credentials (use strong, unique values!) ----
POSTGRES_USER=samudai
POSTGRES_PASSWORD=CHANGE_ME
MONGO_USER=samudai
MONGO_PASSWORD=CHANGE_ME
REDIS_PASSWORD=CHANGE_ME
RABBITMQ_USER=samudai
RABBITMQ_PASSWORD=CHANGE_ME

# ---- App config ----
ENVIRONMENT=production
JWT_KEY=CHANGE_ME_long_random_secret
GIN_MODE=release

# Host port vars are unused in prod (app ports are not published; Caddy fronts
# everything on 80/443) but kept so the base compose file resolves cleanly.
GATEWAY_PORT=4000
FRONTEND_PORT=3000
BACKEND_PORT=8081
SERVICE_NODE_PORT=8082
SERVICE_NOTIFICATION_PORT=8083

# ---- Backend (Go) third-party secrets ----
GITHUB_WEBHOOK_SECRET=CHANGE_ME
MORALIS_API_KEY=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Note: the frontend is deployed as the prebuilt ghcr.io/samudai/dashboard-samudai
# image, whose REACT_APP_GATEWAY (https://gcn.samudai.xyz) is baked in at CI build
# time from frontend/.production.env — it is NOT read from this file.

# ---- gateway-consumer-node third-party secrets ----
AWS_ACCESS_KEY_ID=
AWS_SCERET_ACCESS_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SIGNING_SECRET=
STRIPE_MONTHLY_PRICE_ID=
STRIPE_YEARLY_PRICE_ID=
STRIPE_PRODUCT_ID=
SAMUDAI_MAIL=
SAMUDAI_MAIL_PASSWORD=
NEYNAR_API_KEY=
TWITTER_CLIENT_ID=
LIGHTHOUSE_TOKEN=

# ---- service-node (Twitter / x) secrets ----
RAPID_API_KEY=
DECRYPTION_KEY=

# ---- Bots ----
DISCORD_BOT_TOKEN=
DISCORD_APP_ID=
TELEGRAM_BOT_ID=
TELEGRAM_USERNAME=samudai_bot
