# Caddy reverse proxy for the single-VM production deploy.
# Automatic HTTPS (Let's Encrypt) is on by default for real domains — make sure
# the A/AAAA records for these hosts point at this VM before starting Caddy.
#
# Routing mirrors the consolidated stack:
#   app.samudai.xyz           -> frontend (static dashboard, nginx :80)
#   gcn.samudai.xyz           -> gateway-consumer-node (client API gateway :8080)
#   ge.samudai.xyz            -> backend monolith's /external module (third-party webhooks)
#   notifications.samudai.xyz -> service-notification (Socket.IO + REST :8080)
#
# Set an email for ACME notifications (optional but recommended).
{
	email admin@samudai.xyz
}

# Frontend (React dashboard)
app.samudai.xyz {
	encode gzip
	reverse_proxy frontend:80
}

# Client API gateway
gcn.samudai.xyz {
	encode gzip
	reverse_proxy gateway-consumer-node:8080
}

# Real-time notifications (Socket.IO + REST). The dashboard connects here
# directly via REACT_APP_NOTIFICATIONS_URL. Caddy upgrades the WebSocket
# transport automatically, so a plain reverse_proxy is sufficient.
notifications.samudai.xyz {
	encode gzip
	reverse_proxy service-notification:8080
}

# External integrations gateway — third-party inbound webhooks (GitHub App,
# Snapshot, Telegram) plus the Discord bot's server-side calls. The former
# standalone gateway-external is now the monolith's `external` module, so we
# prepend /external here. This preserves the original public webhook URLs
# (root paths) — no need to reconfigure GitHub/Snapshot/Telegram.
ge.samudai.xyz {
	encode gzip
	rewrite * /external{uri}
	reverse_proxy backend:8080
}

# Other legacy hosts retired by the monorepo consolidation are intentionally NOT mapped:
#   webhook/points/try.samudai.xyz -> those standalone services no longer exist
# Add a block here (host { reverse_proxy <service>:<port> }) if any is revived.
