# Copy to .env and adjust. Local defaults below let `docker compose up` work
# out of the box; fill the blank placeholders for full third-party functionality.

# ---- Stateful dependency credentials (match docs/db-migration defaults) ----
POSTGRES_USER=piyushhbhutoria
POSTGRES_PASSWORD=password
MONGO_USER=mongoadmin
MONGO_PASSWORD=password
REDIS_PASSWORD=password
RABBITMQ_USER=rabbitmq
RABBITMQ_PASSWORD=password

# ---- Host ports (override if they clash locally) ----
GATEWAY_PORT=4000
FRONTEND_PORT=3000
BACKEND_PORT=8081
SERVICE_NODE_PORT=8082

# ---- Shared app config ----
ENVIRONMENT=local
JWT_KEY=local-dev-jwt-key
GIN_MODE=release

# ---- Backend (Go) third-party secrets — blank = feature disabled locally ----
GITHUB_WEBHOOK_SECRET=secretproduction
MORALIS_API_KEY=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ---- Frontend build-time gateway URL (baked into the bundle) ----
REACT_APP_GATEWAY=http://localhost:4000/

# ---- gateway-consumer-node third-party secrets ----
AWS_ACCESS_KEY_ID=
AWS_SCERET_ACCESS_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SIGNING_SECRET=
STRIPE_MONTHLY_PRICE_ID=
STRIPE_YEARLY_PRICE_ID=
STRIPE_PRODUCT_ID=
SAMUDAI_MAIL=
SAMUDAI_MAIL_PASSWORD=
NEYNAR_API_KEY=
TWITTER_CLIENT_ID=
LIGHTHOUSE_TOKEN=

# ---- service-node (Twitter / x) secrets ----
RAPID_API_KEY=
DECRYPTION_KEY=

# ---- Bots ----
DISCORD_BOT_TOKEN=
DISCORD_APP_ID=
TELEGRAM_BOT_ID=
TELEGRAM_USERNAME=samudai_bot
